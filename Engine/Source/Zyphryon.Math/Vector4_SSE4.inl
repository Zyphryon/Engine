    // -=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-
    // -=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-

    Vector4 Vector4::Normalize(Vector4 Vector)
    {
        return Vector4(_mm_mul_ps(Vector.mData, _mm_set1_ps(1.0f / Vector.GetLength())));
    }

    // -=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-
    // -=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-

    Real32 Vector4::Dot(Vector4 P0, Vector4 P1)
    {
        Type V0 = _mm_mul_ps(P0.mData, P1.mData);
        Type V1 = _mm_shuffle_ps(V0, V0, _MM_SHUFFLE(2, 3, 0, 1));

        V0 = _mm_add_ps(V0, V1);
        V1 = _mm_shuffle_ps(V0, V0, _MM_SHUFFLE(1, 0, 3, 2));
        return _mm_cvtss_f32(_mm_add_ps(V0, V1));
    }

    // -=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-
    // -=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-

    Real32 Vector4::Dot3(Vector4 P0, Vector4 P1)
    {
        const Type V0 = _mm_mul_ps(P0.mData, P1.mData);
        const Type V1 = _mm_shuffle_ps(V0, V0, _MM_SHUFFLE(1, 1, 1, 1));
        const Type V2 = _mm_shuffle_ps(V0, V0, _MM_SHUFFLE(2, 2, 2, 2));
        return _mm_cvtss_f32(_mm_add_ss(_mm_add_ss(V0, V1), V2));
    }

    // -=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-
    // -=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-

    Vector4 Vector4::Cross3(Vector4 P0, Vector4 P1)
    {
        const Type V0 = _mm_shuffle_ps(P0.mData, P0.mData, _MM_SHUFFLE(3, 0, 2, 1));
        const Type V1 = _mm_shuffle_ps(P1.mData, P1.mData, _MM_SHUFFLE(3, 1, 0, 2));
        const Type V2 = _mm_shuffle_ps(P0.mData, P0.mData, _MM_SHUFFLE(3, 1, 0, 2));
        const Type V3 = _mm_shuffle_ps(P1.mData, P1.mData, _MM_SHUFFLE(3, 0, 2, 1));
        return Vector4(_mm_sub_ps(_mm_mul_ps(V0, V1), _mm_mul_ps(V2, V3)));
    }

    // -=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-
    // -=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-

